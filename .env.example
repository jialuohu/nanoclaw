
# --- Authentication (one of these is required) ---

# Claude Code OAuth token (from `claude login`)
CLAUDE_CODE_OAUTH_TOKEN=

# OR: Direct Anthropic API key
ANTHROPIC_API_KEY=

# Optional: custom Anthropic API base URL
ANTHROPIC_BASE_URL=

# Optional: Anthropic auth token (for enterprise proxy setups)
ANTHROPIC_AUTH_TOKEN=

# --- Agent configuration ---

# Claude model for agent containers (e.g. claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5)
CLAUDE_MODEL=claude-sonnet-4-6

# Assistant display name (used in trigger pattern @Name)
ASSISTANT_NAME=Andy

# Set to true if the assistant has its own phone number (affects WhatsApp behavior)
ASSISTANT_HAS_OWN_NUMBER=

# --- Telegram ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated additional bot tokens for agent swarm (each subagent gets its own bot)
TELEGRAM_BOT_POOL=

# Comma-separated Telegram user IDs allowed to interact with the bot (empty = no restriction)
TELEGRAM_ALLOWED_USERS=

# --- Voice transcription ---

# OpenAI API key for voice message transcription (Whisper)
OPENAI_API_KEY=

# --- Google Calendar ---

# How many minutes before an event to send a reminder (default 15)
GCAL_REMINDER_MINUTES=15

# Hour of day (0-23) to send the daily agenda (default 8)
GCAL_AGENDA_HOUR=8
