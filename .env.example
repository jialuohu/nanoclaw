
# Claude model for agent containers (e.g. claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5)
CLAUDE_MODEL=claude-sonnet-4-6

# Added by skill
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to interact with the bot (empty = no restriction)
TELEGRAM_ALLOWED_USERS=

# OpenAI API key for voice message transcription (Whisper)
OPENAI_API_KEY=

# Google Calendar: how many minutes before an event to send a reminder (default 15)
GCAL_REMINDER_MINUTES=15

# Google Calendar: hour of day (0-23) to send the daily agenda (default 8)
GCAL_AGENDA_HOUR=8
